# LLM7 — get a free token at https://dash.llm7.io
LLM7_API_KEY=unused
# Free-tier model (gpt-4o-mini ids are often unavailable; codestral-latest works)
LLM7_MODEL=codestral-latest

# Optional: adds a password-free "Sign in as demo user" button to /login for the
# matching seeded account. Ignored when NODE_ENV=production.
# DEMO_USER_EMAIL=demo@recall.local
